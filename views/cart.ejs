<%- include('partials/head') %>

<main class="ct-page site-wrap">
  <section class="ct-main">
    <header class="ct-head">
      <h1><%= pick(locale, "Ваша корзина", "Сіздің себетіңіз") %></h1>
      <p style="color: var(--text-muted); font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; font-size: 0.85rem;">
        Aspap.kz — <%= pick(locale, "Искусство звука", "Дыбыс өнері") %>
      </p>
    </header>

    <div class="ct-grid">
      <section class="ct-items" id="cart-items-container">
        <!-- Filled by JS -->
      </section>

      <aside class="ct-summary">
        <h2><%= pick(locale, "Итого к оплате", "Төлем қорытындысы") %></h2>
        <div class="ct-lines">
          <div>
            <span><%= pick(locale, "Промежуточный итог", "Аралық сома") %></span>
            <span id="subtotal">0 ₸</span>
          </div>
          <div>
            <span><%= pick(locale, "Доставка", "Жеткізу") %></span>
            <span class="ct-green"><%= pick(locale, "Бесплатно", "Тегін") %></span>
          </div>
          <div>
            <span><%= pick(locale, "Скидка (VIP)", "Жеңілдік (VIP)") %></span>
            <span id="discount">-0 ₸</span>
          </div>
        </div>

        <div class="ct-total">
          <span><%= pick(locale, "Всего", "Барлығы") %></span>
          <strong id="grand-total">0 ₸</strong>
        </div>

        <button onclick="goToCheckout()" class="ct-primary-btn">
          <%= pick(locale, "Оформить заказ", "Тапсырысты рәсімдеу") %> →
        </button>

        <a href="/catalog" class="ct-secondary-btn">
          <%= pick(locale, "Продолжить покупки", "Сауданы жалғастыру") %>
        </a>

        <div style="margin-top: 4rem; padding-top: 3rem; border-top: 1px solid var(--border-light); display: flex; gap: 1.5rem; align-items: center;">
          <div style="width: 40px; height: 40px; background: var(--bg-soft); border-radius: 50%; display: grid; place-items: center; font-size: 1.2rem;">🛡</div>
          <p style="font-size: 0.8rem; color: var(--text-muted); line-height: 1.4;">
            <%= pick(
              locale,
              "Безопасная оплата. Все инструменты проходят профессиональную настройку перед отправкой.",
              "Қауіпсіз төлем. Барлық аспаптар жіберу алдында кәсіби баптаудан өтеді."
            ) %>
          </p>
        </div>
      </aside>
    </div>
  </section>
</main>

<script>
function formatKzt(value) {
    return new Intl.NumberFormat("ru-RU").format(value) + " ₸";
}

function renderCart() {
    const container = document.getElementById('cart-items-container');
    const items = JSON.parse(localStorage.getItem('aspap-cart-v1') || '[]');
    
    if (items.length === 0) {
        container.innerHTML = `
            <div style="text-align: center; padding: 10rem 0; background: var(--bg-soft); border-radius: var(--radius-lg);">
                <div style="font-size: 4rem; margin-bottom: 2rem;">🛍</div>
                <h3 style="font-size: 2rem; margin-bottom: 1rem;"><%= pick(locale, "Корзина пуста", "Себет бос") %></h3>
                <p style="margin-bottom: 3rem; color: var(--text-muted);"><%= pick(locale, "Выберите инструменты в нашем каталоге", "Каталогтан аспап таңдаңыз") %></p>
                <a href="/catalog" class="btn-prime"><%= pick(locale, "В каталог", "Каталогқа өту") %></a>
            </div>
        `;
        updateSummary(0);
        return;
    }

    let html = '';
    let total = 0;
    items.forEach(item => {
        total += item.price * item.qty;
        html += `
            <article class="ct-item">
              <img src="${item.image}" alt="${item.name}" />
              <div class="ct-item-body">
                <div class="ct-item-top">
                  <div>
                    <h3 style="font-family: var(--font-serif);">${item.name}</h3>
                    <p style="font-size: 0.9rem; color: var(--text-muted); font-weight: 600;"><%= pick(locale, "Материал", "Материал") %>: ${item.material || 'Орех'}</p>
                  </div>
                  <button onclick="removeFromCart(${item.id})" type="button" class="ct-remove">×</button>
                </div>
                <div class="ct-item-bottom">
                  <div class="ct-qty-box">
                    <button onclick="changeQty(${item.id}, -1)" type="button">−</button>
                    <span>${item.qty}</span>
                    <button onclick="changeQty(${item.id}, 1)" type="button">+</button>
                  </div>
                  <strong style="font-size: 1.8rem; font-family: var(--font-serif); color: var(--gold-dark);">${formatKzt(item.price * item.qty)}</strong>
                </div>
              </div>
            </article>
        `;
    });
    container.innerHTML = html;
    updateSummary(total);
}

function changeQty(id, delta) {
    let items = JSON.parse(localStorage.getItem('aspap-cart-v1') || '[]');
    const item = items.find(i => i.id === id);
    if (item) {
        item.qty += delta;
        if (item.qty <= 0) {
            items = items.filter(i => i.id !== id);
        }
        localStorage.setItem('aspap-cart-v1', JSON.stringify(items));
        renderCart();
        updateCartCount();
    }
}

function removeFromCart(id) {
    let items = JSON.parse(localStorage.getItem('aspap-cart-v1') || '[]');
    items = items.filter(i => i.id !== id);
    localStorage.setItem('aspap-cart-v1', JSON.stringify(items));
    renderCart();
    updateCartCount();
    showToast('<%= pick(locale, "Товар удален", "Тауар жойылды") %>');
}

function updateSummary(totalPrice) {
    const items = JSON.parse(localStorage.getItem('aspap-cart-v1') || '[]');
    const qty = items.reduce((s, i) => s + i.qty, 0);
    const discount = qty >= 2 ? 10000 : 0;
    const grandTotal = Math.max(0, totalPrice - discount);
    
    document.getElementById('subtotal').textContent = formatKzt(totalPrice);
    document.getElementById('discount').textContent = '-' + formatKzt(discount);
    document.getElementById('grand-total').textContent = formatKzt(grandTotal);
    if (typeof updateCartCount === 'function') updateCartCount();
}

function goToCheckout() {
    const items = JSON.parse(localStorage.getItem('aspap-cart-v1') || '[]');
    if (items.length === 0) {
        showToast('<%= pick(locale, "Корзина пуста", "Себет бос") %>', 'error');
        return;
    }
    window.location.href = '/checkout';
}

function updateCartCount() {
    let cart = JSON.parse(localStorage.getItem('aspap-cart-v1') || '[]');
    const total = cart.reduce((sum, item) => sum + item.qty, 0);
    const pill = document.getElementById('cart-count');
    if (pill) pill.textContent = total;
}

document.addEventListener('DOMContentLoaded', renderCart);
</script>

<%- include('partials/foot') %>
