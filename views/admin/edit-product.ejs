<%- include('../partials/head') %>

<main class="admin-page site-wrap">
    <div class="admin-nav">
        <a href="/admin/products" class="active"><%= pick(locale, "Товары", "Тауарлар") %></a>
        <a href="/admin/orders"><%= pick(locale, "Заказы", "Тапсырыстар") %></a>
        <a href="/admin/custom-orders"><%= pick(locale, "Заявки", "Өтінімдер") %></a>
        <a href="/admin/users"><%= pick(locale, "Пользователи", "Қолданушылар") %></a>
    </div>

    <header style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 4rem;">
        <h1 style="font-size: 3rem;"><%= product ? pick(locale, "Редактировать", "Өңдеу") : pick(locale, "Добавить", "Қосу") %> <%= pick(locale, "товар", "тауар") %></h1>
        <a href="/admin/products" class="btn-ghost" style="padding: 0.8rem 2rem; font-size: 0.8rem;"><%= pick(locale, "Назад", "Артқа") %></a>
    </header>

    <div style="background: white; padding: 4rem; border-radius: var(--radius-md); box-shadow: var(--shadow-soft); border: 1px solid var(--border-light);">
        <form action="/admin/products/save" method="POST" class="auth-form" id="admin-product-form">
            <% if (product) { %>
                <input type="hidden" name="id" value="<%= product.id %>">
            <% } %>
            
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem;">
                <div class="field">
                    <label><%= pick(locale, "Название", "Атауы") %></label>
                    <input name="name" value="<%= product?.name || '' %>" required placeholder="<%= pick(locale, "Золотая домбра", "Алтын домбыра") %>">
                </div>
                <div class="field">
                    <label><%= pick(locale, "Вид дерева", "Ағаш түрі") %></label>
                    <% const woodOps = [
                        { id: "Тянь-Шаньская ель", title: pick(locale, "Тянь-Шаньская ель", "Тянь-Шань шыршасы") },
                        { id: "Орех", title: pick(locale, "Орех", "Жаңғақ") },
                        { id: "Клён", title: pick(locale, "Клён", "Үйеңкі") },
                        { id: "Абрикос", title: pick(locale, "Абрикос", "Өрік") },
                        { id: "Красное дерево", title: pick(locale, "Красное дерево", "Қызыл ағаш") },
                        { id: "Комбинированный", title: pick(locale, "Комбинированный", "Аралас") }
                    ]; %>
                    <select name="material" required>
                        <% woodOps.forEach(op => { %>
                            <option value="<%= op.id %>" <%= (product?.material || 'Орех') === op.id ? 'selected' : '' %>><%= op.title %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="field">
                    <label><%= pick(locale, "Тип домбры", "Домбыра түрі") %></label>
                    <% const styleOps = [
                        { id: "Классическая", title: pick(locale, "Классическая", "Классикалық") },
                        { id: "Концертная", title: pick(locale, "Концертная", "Концерттік") },
                        { id: "Премиум резонанс", title: pick(locale, "Премиум резонанс", "Премиум резонанс") }
                    ]; %>
                    <select name="badge" required>
                        <% styleOps.forEach(op => { %>
                            <option value="<%= op.id %>" <%= (product?.badge || 'Классическая') === op.id ? 'selected' : '' %>><%= op.title %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="field">
                    <label><%= pick(locale, "Цена", "Бағасы") %> (₸)</label>
                    <input type="number" min="0" name="price" value="<%= product?.price || 0 %>" required>
                </div>
                <div class="field">
                    <label><%= pick(locale, "Склад", "Қойма") %> (шт)</label>
                    <input type="number" min="0" name="stock" value="<%= product?.stock || 10 %>" required>
                </div>
                <div class="field">
                    <label><%= pick(locale, "Часы работы мастера", "Шебер сағаты") %></label>
                    <input type="number" min="1" name="craftsmanship_hours" value="<%= product?.craftsmanship_hours || 120 %>" required>
                </div>
                <div class="field">
                    <label><%= pick(locale, "Мастер", "Шебер") %></label>
                    <input name="master_name" value="<%= product?.master_name || '' %>" placeholder="<%= pick(locale, "Алпамыс", "Алпамыс") %>">
                </div>
                <div class="field">
                    <label><%= pick(locale, "Город", "Қала") %></label>
                    <input name="city" value="<%= product?.city || 'Алматы' %>">
                </div>
            </div>

            <div class="field" style="margin-top: 2rem;">
                <label><%= pick(locale, "Фото товара", "Тауар фотосы") %></label>
                <% 
                  let initialImages = [];
                  try {
                    initialImages = JSON.parse(product?.images_json || "[]");
                    if (!Array.isArray(initialImages)) initialImages = [];
                  } catch {
                    initialImages = [];
                  }
                  if (!initialImages.length && product?.image) initialImages = [product.image];
                %>
                <input type="hidden" name="image" id="admin-image-url" value="<%= product?.image || (initialImages[0] || '') %>" required>
                <input type="hidden" name="images_json" id="admin-images-json" value="<%= JSON.stringify(initialImages) %>">

                <div style="display:grid; grid-template-columns: 1fr; gap: 1.2rem;">
                    <div id="admin-images-grid" style="display:grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 1rem;"></div>

                    <div style="display:grid; grid-template-columns: 1fr 1fr; gap: 1.2rem; align-items:end;">
                        <div class="field">
                            <label><%= pick(locale, "Загрузить с компьютера (несколько)", "Компьютерден жүктеу (бірнеше)") %></label>
                            <input type="file" id="admin-image-file" accept="image/png,image/jpeg,image/webp" multiple>
                        </div>
                        <div class="field">
                            <label><%= pick(locale, "Добавить по ссылке", "Сілтеме арқылы қосу") %></label>
                            <div style="display:flex; gap: 0.75rem;">
                                <input id="admin-image-link" placeholder="https://..." style="flex:1;">
                                <button type="button" class="btn-ghost" style="padding: 0.8rem 1rem;" onclick="addImageLink()"><%= pick(locale, "Добавить", "Қосу") %></button>
                            </div>
                        </div>
                    </div>
                    <div style="color: var(--text-muted); font-weight: 650; line-height: 1.6;">
                        <%= pick(locale, "Выберите несколько фото. Одно из них будет обложкой товара.", "Бірнеше фото таңдаңыз. Біреуі тауардың мұқабасы болады.") %>
                    </div>
                </div>
            </div>

            <div class="field" style="margin-top: 2rem;">
                <label><%= pick(locale, "Аудио (голос инструмента)", "Аудио (аспап үні)") %></label>
                <div style="display:grid; grid-template-columns: 1fr 1fr; gap: 2rem; align-items:start;">
                    <div style="border: 1px solid var(--border-light); border-radius: var(--radius-md); background: var(--bg-soft); padding: 1.25rem;">
                        <div style="font-weight: 900; margin-bottom: 0.8rem; color: var(--gold-dark);"><%= pick(locale, "Прослушать", "Тыңдау") %></div>
                        <audio id="admin-audio-preview" controls style="width:100%;" src="<%= product?.audio_url || '' %>"></audio>
                    </div>
                    <div>
                        <input type="hidden" name="audio_url" id="admin-audio-url" value="<%= product?.audio_url || '' %>">
                        <div class="field">
                            <label><%= pick(locale, "Загрузить с компьютера", "Компьютерден жүктеу") %></label>
                            <input type="file" id="admin-audio-file" accept="audio/mpeg,audio/mp3,audio/ogg,audio/wav">
                        </div>
                        <div class="field" style="margin-top: 1rem;">
                            <label><%= pick(locale, "Или ссылка", "Немесе сілтеме") %></label>
                            <input id="admin-audio-link" value="<%= product?.audio_url || '' %>" placeholder="/audio/dombra-1.mp3 или https://...">
                        </div>
                        <button type="button" class="btn-ghost" style="margin-top: 1rem; padding: 0.8rem 1.2rem;" onclick="applyAudioLink()">
                            <%= pick(locale, "Применить ссылку", "Сілтемені қолдану") %>
                        </button>
                    </div>
                </div>
            </div>

            <div class="field" style="margin-top: 2rem;">
                <label><%= pick(locale, "Краткое описание", "Қысқаша сипаттама") %></label>
                <textarea name="description" rows="3" style="width: 100%; padding: 1.2rem; border-radius: var(--radius-sm); border: 1px solid var(--border-light); background: var(--bg-soft); font-family: inherit;"><%= product?.description || '' %></textarea>
            </div>

            <div class="field" style="margin-top: 2rem;">
                <label><%= pick(locale, "Полное описание", "Толық сипаттама") %></label>
                <textarea name="long_description" rows="6" style="width: 100%; padding: 1.2rem; border-radius: var(--radius-sm); border: 1px solid var(--border-light); background: var(--bg-soft); font-family: inherit;"><%= product?.long_description || '' %></textarea>
            </div>

            <div style="margin-top: 3rem;">
                <button type="submit" class="btn-prime" style="width: 100%;"><%= pick(locale, "Сохранить изменения", "Өзгерістерді сақтау") %></button>
            </div>
        </form>
    </div>
</main>

<script>
function getImages() {
    try {
        const arr = JSON.parse(document.getElementById('admin-images-json').value || '[]');
        return Array.isArray(arr) ? arr.filter(Boolean) : [];
    } catch {
        return [];
    }
}

function setImages(images) {
    const clean = (images || []).filter(Boolean).slice(0, 12);
    document.getElementById('admin-images-json').value = JSON.stringify(clean);
    const cover = document.getElementById('admin-image-url').value;
    if (!cover && clean[0]) document.getElementById('admin-image-url').value = clean[0];
    if (cover && !clean.includes(cover) && clean[0]) document.getElementById('admin-image-url').value = clean[0];
    renderImages();
}

function setCover(url) {
    document.getElementById('admin-image-url').value = url;
    renderImages();
}

function removeImage(url) {
    const next = getImages().filter((u) => u !== url);
    setImages(next);
}

function addImageLink() {
    const input = document.getElementById('admin-image-link');
    const link = String(input.value || '').trim();
    if (!link) return;
    const next = getImages();
    next.push(link);
    input.value = '';
    setImages(next);
}

function applyAudioLink() {
    const link = document.getElementById('admin-audio-link').value.trim();
    document.getElementById('admin-audio-url').value = link;
    document.getElementById('admin-audio-preview').src = link;
}

async function uploadFile(kind, file) {
    const dataUrl = await new Promise((resolve, reject) => {
        const r = new FileReader();
        r.onload = () => resolve(String(r.result || ''));
        r.onerror = () => reject(new Error('read error'));
        r.readAsDataURL(file);
    });

    const res = await fetch('/admin/uploads', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ kind, dataUrl, name: file.name })
    });
    const json = await res.json().catch(() => ({}));
    if (!res.ok) throw new Error(json.error || 'upload error');
    return json.url;
}

function renderImages() {
    const grid = document.getElementById('admin-images-grid');
    const images = getImages();
    const cover = document.getElementById('admin-image-url').value;
    if (!grid) return;

    if (!images.length) {
        grid.innerHTML = `<div style="grid-column: span 4; padding: 2.2rem; border: 1px dashed rgba(15,11,8,0.15); border-radius: var(--radius-md); background: var(--bg-soft); color: var(--text-muted); font-weight: 700;"><%= pick(locale, "Пока нет фото", "Фото жоқ") %></div>`;
        return;
    }

    grid.innerHTML = images.map((url) => {
        const isCover = url === cover || (!cover && images[0] === url);
        return `
          <div style="border: 1px solid var(--border-light); border-radius: var(--radius-md); overflow:hidden; background: var(--bg-soft); position: relative;">
            <img src="${url}" alt="img" style="width:100%; height:160px; object-fit:cover; display:block;">
            <div style="position:absolute; inset: 10px 10px auto 10px; display:flex; gap:0.5rem; justify-content: space-between;">
              <button type="button" class="btn-ghost" data-action="cover" data-url="${encodeURIComponent(url)}" style="padding: 0.45rem 0.75rem; font-size:0.65rem; background: rgba(255,255,255,0.9);">${isCover ? '<%= pick(locale, "Обложка", "Мұқаба") %>' : '<%= pick(locale, "Сделать обложкой", "Мұқаба ету") %>'}</button>
              <button type="button" class="btn-ghost" data-action="remove" data-url="${encodeURIComponent(url)}" style="padding: 0.45rem 0.75rem; font-size:0.65rem; background: rgba(255,255,255,0.9); border-color:#fceaea; color:#e74c3c;"><i class="fa-solid fa-trash"></i></button>
            </div>
          </div>
        `;
    }).join('');
}

document.getElementById('admin-image-file').addEventListener('change', async (e) => {
    const files = Array.from((e.target.files || []));
    if (!files.length) return;
    e.target.value = '';
    try {
        const urls = [];
        for (const file of files) {
            const url = await uploadFile('image', file);
            urls.push(url);
        }
        const next = getImages().concat(urls);
        setImages(next);
        if (!document.getElementById('admin-image-url').value && urls[0]) document.getElementById('admin-image-url').value = urls[0];
        showToast('<%= pick(locale, "Фото загружены", "Фото жүктелді") %>');
    } catch (err) {
        showToast(String(err.message || err), 'error');
    }
});

document.getElementById('admin-audio-file').addEventListener('change', async (e) => {
    const file = e.target.files && e.target.files[0];
    if (!file) return;
    try {
        const url = await uploadFile('audio', file);
        document.getElementById('admin-audio-url').value = url;
        document.getElementById('admin-audio-link').value = url;
        document.getElementById('admin-audio-preview').src = url;
        showToast('<%= pick(locale, "Аудио загружено", "Аудио жүктелді") %>');
    } catch (err) {
        showToast(String(err.message || err), 'error');
    }
});

document.addEventListener('DOMContentLoaded', () => {
    renderImages();
});

document.getElementById('admin-images-grid')?.addEventListener('click', (e) => {
    const btn = e.target.closest('button[data-action]');
    if (!btn) return;
    const action = btn.getAttribute('data-action');
    const url = decodeURIComponent(btn.getAttribute('data-url') || '');
    if (!url) return;
    if (action === 'cover') setCover(url);
    if (action === 'remove') removeImage(url);
});
</script>

<%- include('../partials/foot') %>
